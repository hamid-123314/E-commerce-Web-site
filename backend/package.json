    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "redis": "^4.6.0",
    "resend": "^2.0.0",
    "stripe": "^14.0.0",
